# Supabase — copy this file to .env.local and fill in your values
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Only used server-side (Server Actions). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Public URL used to construct auth redirect URLs (e.g. email verification links).
# Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Low stock email alerts (SendGrid)
OPERATOR_EMAIL=<email-to-receive-low-stock-alerts>
SENDGRID_API_KEY=<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=<your-verified-sender-email>
